{
  "name": "payforme-helper",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite --port 5000 --host",
    "dev:backend": "tsx watch server.ts",
    "build": "vite build",
    "start": "tsx server.ts",
    "preview": "vite preview --port 5000 --host",
    "db:init": "tsx -e \"import('./server.ts').then(m => m.initDatabase && m.initDatabase())\"",
    "db:migrate": "node migrations/run-migration.js",
    "db:seed": "node scripts/seed_accounts.js",
    "lint": "eslint src/ server.ts --ext .ts,.tsx",
    "lint:fix": "eslint src/ server.ts --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"server.ts\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"server.ts\" \"*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.2.3",
    "clsx": "2.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "serve": "^14.2.6",
    "tailwindcss": "4.1.17",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^1.6.0"
  }
}
